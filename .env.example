# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mapplus:mapplus_dev@localhost:5432/mapplus

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with strong random strings in production
# Generate: openssl rand -base64 64
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ─── Storage (MinIO for local dev, Cloudflare R2 in production) ────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=mapplus
STORAGE_SECRET_KEY=mapplus_dev
STORAGE_BUCKET=mapplus
STORAGE_REGION=auto

# ─── CDN ───────────────────────────────────────────────────────────────────────
CDN_URL=http://localhost:9000/mapplus

# ─── QR Codes ──────────────────────────────────────────────────────────────────
QR_BASE_URL=http://localhost:3000/q
