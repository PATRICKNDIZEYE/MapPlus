{
  "name": "mallguide",
  "private": true,
  "scripts": {
    "boot": "bash scripts/dev.sh",
    "dev": "turbo dev",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "seed:users": "node scripts/seed-users.js",
    "transfer-map": "node scripts/transfer-map.js",
    "build-mall": "node scripts/build-mall.js",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "pnpm --filter @mallguide/api db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
